# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment variables
.env
.env.local
frontend/.env
backend/.env
ai-service/.env

# Build outputs
frontend/dist/
backend/dist/

# Uploads (runtime data, not source)
backend/uploads/*
!backend/uploads/.gitkeep

# Python
ai-service/__pycache__/
ai-service/*.pyc
ai-service/venv/
ai-service/.venv/

# Hugging Face model cache (downloaded at setup time, not committed)
ai-service/models/
ai-service/.cache/

# Logs
*.log
npm-debug.log*

# Editor/OS
.vscode/
.idea/
.DS_Store
